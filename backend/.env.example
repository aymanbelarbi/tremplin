APP_NAME=Tremplin
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Casablanca
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Base de données : MySQL ---
# Utilise XAMPP pour MySQL local.
# Assure-toi que MySQL est démarré dans XAMPP.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tremplin
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Pour traitement en arrière-plan, mettre QUEUE_CONNECTION=database
# et lancer `php artisan queue:work`.
QUEUE_CONNECTION=sync

CACHE_STORE=database
CACHE_PREFIX=

# --- Mail : log en dev, SMTP en prod ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@tremplin.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Frontend + Sanctum ---
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# --- Admin seed (à changer en production) ---
ADMIN_EMAIL=admin@tremplin.ma
ADMIN_PASSWORD="tremplin --admin"

